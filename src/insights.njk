<main id="main">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <p class="section-eyebrow fade-in">Insights</p>
      <h1 class="fade-in">Engineering Knowledge, Shared</h1>
      <p class="lead fade-in">Technical articles on energy compliance, HVAC design, and the practical realities of mechanical engineering in Southern California.</p>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="section">
    <div class="container">
      <div class="insights-grid">

        {% for post in collections.insights %}
        <article class="article-card fade-in">
          <a href="{{ post.url }}" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;height:100%;">
            {% if post.data.featuredImage %}
            <div class="article-card-image">
              <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}" width="800" height="450" loading="lazy" decoding="async">
            </div>
            {% endif %}
            <div class="article-card-body">
              {% if post.data.tag %}
              <span class="article-tag">{{ post.data.tag }}</span>
              {% endif %}
              <h3>{{ post.data.title }}</h3>
              {% if post.data.excerpt %}
              <p>{{ post.data.excerpt }}</p>
              {% else %}
              <p>{{ post.content | excerpt }}</p>
              {% endif %}
              <div class="article-meta">{{ post.date | dateShort }} · {{ post.content | readingTime }}</div>
            </div>
          </a>
        </article>
        {% endfor %}

        {% if collections.insights.length == 0 %}
        <div style="grid-column: 1 / -1; text-align: center; padding: var(--space-12) 0;">
          <p style="color: var(--color-text-muted);">Articles coming soon. Check back for technical insights on HVAC design, energy compliance, and mechanical engineering.</p>
        </div>
        {% endif %}

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section fade-in">
    <div class="container">
      <h2>Have a Technical Question?</h2>
      <p>We're happy to discuss engineering challenges. If it's within our expertise, we'll point you in the right direction — even if it doesn't turn into an engagement.</p>
      <a class="btn btn-primary" href="/contact">Reach Out</a>
    </div>
  </section>

</main>

